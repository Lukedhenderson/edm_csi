{
    "dataset": {
        "batch_size": 4,
        "shuffle": true,
        "num_workers": 4,
        "pin_memory": true
    },
    "model": {
        "architecture": "edm",
        "path_net": ""
    },
    "training": {
        "epochs": 100,
        "learning_rate": 1e-4,
